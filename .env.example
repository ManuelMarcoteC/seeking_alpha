# Copy to .env and fill in. All settings use the QT_ prefix.
# Alpha Vantage key (optional until you have one; the provider stays a stub without it)
QT_ALPHA_VANTAGE_API_KEY=

# Root directory for the data lake (raw/curated/reports + catalog.duckdb)
QT_DATA_DIR=data

# Default ingestion provider: yfinance | synthetic | alpha_vantage
QT_DEFAULT_PROVIDER=yfinance

# Exchange calendar for session alignment
QT_DEFAULT_CALENDAR=XNYS

# Default universe for `qt update` / `qt news update`
QT_DEFAULT_UNIVERSE=NASDAQ

# Anthropic key for the agent layer (`qt agent ...`). Falls back to ANTHROPIC_API_KEY.
QT_ANTHROPIC_API_KEY=
# Bill the agent against a Claude Pro/Max subscription instead of a pay-per-token
# API key. Reuses the OAuth token stored by the official Claude Code CLI, so run
# `claude auth login --claudeai` once first. When true, QT_ANTHROPIC_API_KEY is
# ignored. See "Agent billing via Claude subscription" in the README.
QT_AGENT_USE_SUBSCRIPTION=false
# Where the Claude Code CLI keeps its OAuth credentials (override only if non-default)
QT_AGENT_CREDENTIALS_PATH=~/.claude/.credentials.json
# Agent model & budget knobs (defaults shown)
QT_AGENT_MODEL=claude-opus-4-8
QT_AGENT_MAX_ROUNDS=6

# News / sentiment (defaults shown)
QT_AV_NEWS_PAGE_LIMIT=23
QT_NEWS_RELEVANCE_FLOOR=0.25
QT_NEWS_CUTOFF_LOCAL=15:30
QT_NEWS_DECAY_TAU_DAYS=7.0
# Pinned FinBERT revision — frozen scorer keeps the factor series reproducible
QT_FINBERT_REVISION=4556d13015211d73dccd3fdd39d39232506f3e43
